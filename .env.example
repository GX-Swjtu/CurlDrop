# CurlDrop 配置文件
# 将此文件复制为 .env 并修改配置

# HTTP 端口
CURLDROP_HTTP_PORT=8080

# HTTPS 端口
CURLDROP_HTTPS_PORT=8443

# 文件存储路径
CURLDROP_STORAGE=./uploads

# 用户名
CURLDROP_USER=admin

# 密码
CURLDROP_PASS=admin

# 自动清理天数（0 表示不清理）
CURLDROP_AUTO_CLEAN=0

# 自动生成自签名证书（true/false）
CURLDROP_AUTO_TLS=false

# 证书文件路径（留空则不使用文件证书）
CURLDROP_CERT=
CURLDROP_KEY=
